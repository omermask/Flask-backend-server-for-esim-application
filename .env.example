ENVIRONMENT=development
SECRET_KEY=change_this_to_a_random_64_char_string
API_KEYS_ENCRYPTION_KEY=change_this_to_a_random_32_char_string

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_WORKERS=4

DB_HOST=localhost
DB_PORT=5432
DB_NAME=esim_ego
DB_USER=postgres
DB_PASSWORD=change_this

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=30
RATE_LIMIT_ADMIN_PER_MINUTE=60

SMS_PROVIDER=bulksmsiraq
BULKSMSIRAQ_API_KEY=
BULKSMSIRAQ_SENDER_ID=ESIMEGO
BULKSMSIRAQ_BASE_URL=https://gateway.standingtech.com/api/v5
BULKSMSIRAQ_TIMEOUT=10
OTPIQ_API_KEY=
OTPIQ_SENDER_ID=ESIMEGO
OTPIQ_API_BASE_URL=https://api.otpiq.com/api
OTPIQ_TIMEOUT=10
OTPIQ_WEBHOOK_SECRET=
OTPIQ_WEBHOOK_URL=
 
 PAYMENT_PROVIDERS=zaincash,fib,qicard
ZAINCASH_CLIENT_ID=
ZAINCASH_CLIENT_SECRET=
ZAINCASH_MERCHANT_ID=
ZAINCASH_SECRET=
ZAINCASH_MSISDN=
# ZAINCASH_TEST=true uses https://pg-api-uat.zaincash.iq (UAT)
# ZAINCASH_TEST=false uses https://pg-api.zaincash.iq (production)
# When TEST=true and no creds → simulated mode
ZAINCASH_TEST=true
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=
QICARD_USERNAME=
QICARD_PASSWORD=
QICARD_TERMINAL_ID=
QICARD_SANDBOX=True

# SMS: use "mock" for testing without real API calls
# SMS_PROVIDER=mock
SMS_PROVIDER=bulksmsiraq

ESIM_PROVIDER=esimgo
ESIMGO_API_KEY=
ESIMGO_API_BASE_URL=https://api.esim-go.com/v2.5
ESIMGO_SANDBOX=False
ESIMGO_SANDBOX_BASE_URL=
ESIMGO_TIMEOUT=30
# eSIM mock for testing: ESIM_PROVIDER=mock

# FIB payment
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=
FIB_BASE_URL=https://api.fib.iq
FIB_SANDBOX=False
FIB_SANDBOX_BASE_URL=

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar,fr,tr,ku,fa,ur,de,es,ru,zh,pt
DEFAULT_TIMEZONE=Asia/Baghdad

LOG_LEVEL=WARNING
LOG_FILE=logs/esim-ego.log
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# Firebase Cloud Messaging (push notifications)
# Paste your full Firebase service account JSON here (single line)
FCM_SERVICE_ACCOUNT_JSON=

CORS_ORIGINS=https://yourapp.com

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5
OTP_BLOCK_MINUTES=10
